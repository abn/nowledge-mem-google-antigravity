{
  "nowledge-mem-hooks": {
    "PreInvocation": [
      {
        "type": "command",
        "command": "python3 hooks/session-start.py || python hooks/session-start.py || echo {}",
        "timeout": 10
      }
    ],
    "PreToolUse": [
      {
        "matcher": "call_mcp_tool|mcp_nowledge-mem_.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/nmem-gate.py || python hooks/nmem-gate.py || echo {\\\"decision\\\":\\\"ask\\\"}",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "python3 hooks/session-end.py || python hooks/session-end.py || echo {}",
        "timeout": 20
      }
    ]
  }
}
